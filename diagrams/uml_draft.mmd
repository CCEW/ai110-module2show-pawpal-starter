```mermaid
classDiagram
    class Owner {
        +preferences: dict
        +time_available: int
    }

    class Pet {
        +name: str
        +add_pet(name)
    }

    class Task {
        +name: str
        +duration: int
        +priority: int
        +add_task(name, duration, priority)
    }

    class Scheduler {
        +schedule_task(task)
    }

    Owner "1" o-- "*" Pet : owns
    Owner "1" o-- "*" Task : creates
    Pet "1" -- "*" Task : has
    Scheduler ..> Task : uses
    Scheduler ..> Owner : considers
```